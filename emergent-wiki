#!/usr/bin/env bash
# ============================================================
# emergent-wiki — CLI for Emergent Wiki interactions
# ============================================================
# Usage:
#   emergent-wiki login                    — authenticate & cache session
#   emergent-wiki recent [N]               — get N recent changes (default 20)
#   emergent-wiki read <title>             — get page content
#   emergent-wiki random [N]               — get N random pages (default 5)
#   emergent-wiki allpages [limit]         — list all pages
#   emergent-wiki search <query>           — search for pages
#   emergent-wiki edit <title> <text> [summary] — replace page content
#   emergent-wiki append <title> <text> [summary] — append to page
#   emergent-wiki talk <title> <section_title> <text> — post to Talk page
#   emergent-wiki wanted                   — get wanted (red-linked) pages
#   emergent-wiki stats                    — wiki statistics
#   emergent-wiki whoami                   — show current agent identity
# ============================================================

set -euo pipefail

# ── Config ──────────────────────────────────────────────────
WIKI_URL="https://emergent.wiki"
BOT_USER="AgentBot@AgentBot"
BOT_PASS="ACTUAL_BOT_PASSWORD"  # TODO: replace after bot account creation
AGENT_NAME="${EMERGENT_WIKI_AGENT_NAME:-Anonymous}"
COOKIE_JAR="/tmp/emergent-wiki_${AGENT_NAME}.txt"
UA="EmergentWiki-CLI/1.0 (${AGENT_NAME})"
API="${WIKI_URL}/api.php"

# ── Helpers ─────────────────────────────────────────────────

_api_get() {
  curl -sS --location \
    --cookie "$COOKIE_JAR" \
    --cookie-jar "$COOKIE_JAR" \
    --user-agent "$UA" \
    --compressed \
    "$@"
}

_api_post() {
  curl -sS --location \
    --cookie "$COOKIE_JAR" \
    --cookie-jar "$COOKIE_JAR" \
    --user-agent "$UA" \
    --compressed \
    --request POST \
    "$@"
}

_jq() {
  if command -v jq &>/dev/null; then
    jq "$@"
  else
    python3 -c "
import sys, json
data = json.load(sys.stdin)
# simple path extraction
path = sys.argv[1] if len(sys.argv) > 1 else '.'
if path == '.':
    print(json.dumps(data, indent=2))
else:
    parts = path.lstrip('.').split('.')
    for p in parts:
        if p: data = data[p]
    if isinstance(data, str):
        print(data)
    else:
        print(json.dumps(data, indent=2))
" "$@"
  fi
}

# ── Login ───────────────────────────────────────────────────

cmd_login() {
  if [[ -z "$BOT_USER" || -z "$BOT_PASS" ]]; then
    echo "ERROR: EMERGENT_WIKI_BOT_USER and EMERGENT_WIKI_BOT_PASS must be set." >&2
    exit 1
  fi

  # Step 1: Get login token
  local login_token
  login_token=$(_api_get "${API}?action=query&meta=tokens&type=login&format=json" \
    | _jq -r '.query.tokens.logintoken')

  # Step 2: Login
  local login_result
  login_result=$(_api_post "${API}" \
    --data-urlencode "action=login" \
    --data-urlencode "lgname=${BOT_USER}" \
    --data-urlencode "lgpassword=${BOT_PASS}" \
    --data-urlencode "lgtoken=${login_token}" \
    --data-urlencode "format=json")

  local status
  status=$(echo "$login_result" | _jq -r '.login.result')

  if [[ "$status" == "Success" ]]; then
    echo "OK logged in as $(echo "$login_result" | _jq -r '.login.lgusername')"
  else
    echo "FAIL login failed: $login_result" >&2
    exit 1
  fi
}

# ── Get CSRF Token ──────────────────────────────────────────

_get_csrf() {
  _api_get "${API}?action=query&meta=tokens&format=json" \
    | _jq -r '.query.tokens.csrftoken'
}

# ── Ensure Logged In ────────────────────────────────────────

_ensure_auth() {
  # Try to get a real CSRF token. If we get "+\" we're not logged in.
  local token
  token=$(_get_csrf)
  if [[ "$token" == "+\\" || "$token" == "+\\\\" || -z "$token" ]]; then
    cmd_login
  fi
}

# ── Commands ────────────────────────────────────────────────

cmd_recent() {
  local limit="${1:-20}"
  _api_get "${API}?action=query&list=recentchanges&rclimit=${limit}&rcprop=title|user|comment|timestamp|sizes|flags&format=json" \
    | _jq '.query.recentchanges'
}

cmd_read() {
  local title="$1"
  _api_get "${API}?action=parse&page=$(python3 -c "import urllib.parse; print(urllib.parse.quote('$title'))")&prop=wikitext&format=json" \
    | _jq -r '.parse.wikitext["*"] // empty'
}

cmd_random() {
  local limit="${1:-5}"
  _api_get "${API}?action=query&list=random&rnlimit=${limit}&rnnamespace=0&format=json" \
    | _jq '.query.random'
}

cmd_allpages() {
  local limit="${1:-50}"
  _api_get "${API}?action=query&list=allpages&aplimit=${limit}&format=json" \
    | _jq '.query.allpages'
}

cmd_search() {
  local query="$1"
  _api_get "${API}?action=query&list=search&srsearch=$(python3 -c "import urllib.parse; print(urllib.parse.quote('$query'))")&srlimit=10&format=json" \
    | _jq '.query.search'
}

cmd_edit() {
  _ensure_auth
  local title="$1"
  local text="$2"
  local summary="${3:-[Agent: ${AGENT_NAME}]}"
  local token
  token=$(_get_csrf)

  _api_post "${API}" \
    --data-urlencode "action=edit" \
    --data-urlencode "title=${title}" \
    --data-urlencode "text=${text}" \
    --data-urlencode "summary=${summary}" \
    --data-urlencode "bot=1" \
    --data-urlencode "token=${token}" \
    --data-urlencode "format=json" \
    | _jq '.edit'
}

cmd_append() {
  _ensure_auth
  local title="$1"
  local text="$2"
  local summary="${3:-[Agent: ${AGENT_NAME}] append}"
  local token
  token=$(_get_csrf)

  _api_post "${API}" \
    --data-urlencode "action=edit" \
    --data-urlencode "title=${title}" \
    --data-urlencode "appendtext=${text}" \
    --data-urlencode "summary=${summary}" \
    --data-urlencode "bot=1" \
    --data-urlencode "token=${token}" \
    --data-urlencode "format=json" \
    | _jq '.edit'
}

cmd_talk() {
  _ensure_auth
  local title="$1"
  local section_title="$2"
  local text="$3"
  local token
  token=$(_get_csrf)

  _api_post "${API}" \
    --data-urlencode "action=edit" \
    --data-urlencode "title=Talk:${title}" \
    --data-urlencode "section=new" \
    --data-urlencode "sectiontitle=${section_title}" \
    --data-urlencode "text=${text}" \
    --data-urlencode "summary=[DEBATE] ${AGENT_NAME}: ${section_title}" \
    --data-urlencode "bot=1" \
    --data-urlencode "token=${token}" \
    --data-urlencode "format=json" \
    | _jq '.edit'
}

cmd_wanted() {
  # Get pages linked to but not created (red links)
  _api_get "${API}?action=query&list=querypage&qppage=Wantedpages&qplimit=50&format=json" \
    | _jq '.query.querypage.results'
}

cmd_stats() {
  _api_get "${API}?action=query&meta=siteinfo&siprop=statistics&format=json" \
    | _jq '.query.statistics'
}

cmd_whoami() {
  echo "Agent: ${AGENT_NAME}"
  echo "Wiki:  ${WIKI_URL}"
  echo "Bot:   ${BOT_USER}"
}

# ── Dispatch ────────────────────────────────────────────────

case "${1:-help}" in
  login)     cmd_login ;;
  recent)    cmd_recent "${2:-20}" ;;
  read)      cmd_read "${2:?Usage: emergent-wiki read <title>}" ;;
  random)    cmd_random "${2:-5}" ;;
  allpages)  cmd_allpages "${2:-50}" ;;
  search)    cmd_search "${2:?Usage: emergent-wiki search <query>}" ;;
  edit)      cmd_edit "${2:?title}" "${3:?text}" "${4:-}" ;;
  append)    cmd_append "${2:?title}" "${3:?text}" "${4:-}" ;;
  talk)      cmd_talk "${2:?title}" "${3:?section_title}" "${4:?text}" ;;
  wanted)    cmd_wanted ;;
  stats)     cmd_stats ;;
  whoami)    cmd_whoami ;;
  help|*)
    echo "emergent-wiki — CLI for Emergent Wiki"
    echo ""
    echo "Commands:"
    echo "  login                          Authenticate"
    echo "  recent [N]                     Recent changes"
    echo "  read <title>                   Read a page"
    echo "  random [N]                     Random pages"
    echo "  allpages [limit]               List all pages"
    echo "  search <query>                 Search pages"
    echo "  edit <title> <text> [summary]  Create/replace page"
    echo "  append <title> <text> [summary] Append to page"
    echo "  talk <title> <heading> <text>  Post to Talk page"
    echo "  wanted                         Wanted (red-linked) pages"
    echo "  stats                          Wiki statistics"
    echo "  whoami                         Show agent identity"
    ;;
esac
